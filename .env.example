# IB Gateway connection (used by fetch_ib_historical.py and daily_update.py)
# MDW_IB_HOST="127.0.0.1"          # Local IB Gateway (default)
# MDW_IB_HOST="ib-gateway"          # Cloud IB Gateway (Tailscale MagicDNS)
# MDW_IB_PORT="4001"

# Data lake path override (used by Docker container)
# MDW_DATA_LAKE="/tmp/data-lake"

# Cloudflare R2 storage (used by scripts/sync_to_r2.py)
# R2_ENDPOINT_URL="https://<account-id>.r2.cloudflarestorage.com"
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="market-data"

# Docker Compose scheduler (used by docker/mdw-job/entrypoint.py)
# MDW_SCHEDULE_HOUR="16"
# MDW_SCHEDULE_MINUTE="5"
# MDW_SCHEDULE_TZ="US/Eastern"

# IB Gateway Docker (used by docker-compose.yml)
# TWS_USERID=""
# TRADING_MODE="paper"
# READ_ONLY_API="yes"

# Daily update runner behavior (used by scripts/run_daily_update_job.py)
# MDW_DAILY_UPDATE_MAX_ATTEMPTS="3"
# MDW_DAILY_UPDATE_RETRY_DELAY_SECONDS="300"
# MDW_DAILY_UPDATE_LOG_DIR="$HOME/market-warehouse/logs"
# MDW_WAREHOUSE_DIR="$HOME/market-warehouse"
# MDW_DAILY_UPDATE_SCRIPT=""         # Override path to daily_update.py
# MDW_DAILY_UPDATE_PYTHON_BIN=""     # Override Python binary (defaults to sys.executable)
# MDW_NODE_BIN="/opt/homebrew/bin/node"

# Daily update failure alerts (used by scripts/send_daily_update_failure_email.mjs)
# Required recipients/sender:
# MDW_ALERT_EMAIL_FROM="market-warehouse@example.com"
# MDW_ALERT_EMAIL_TO="you@example.com"
#
# Either provide a full SMTP URL:
# MDW_ALERT_SMTP_URL="smtp://user:pass@mail.example.com:587"
#
# Or provide explicit SMTP fields:
# MDW_ALERT_SMTP_HOST="mail.example.com"
# MDW_ALERT_SMTP_PORT="587"
# MDW_ALERT_SMTP_SECURE="false"
# MDW_ALERT_SMTP_USER="smtp-user"
# MDW_ALERT_SMTP_PASS="smtp-password"
#
# Optional message fields:
# MDW_ALERT_EMAIL_CC=""
# MDW_ALERT_EMAIL_BCC=""
# MDW_ALERT_EMAIL_REPLY_TO=""
# MDW_ALERT_EMAIL_SUBJECT_PREFIX="[Market Data Warehouse]"
#
# Optional AI-generated human-readable incident reports for failure alerts:
# Uses the Cerebras API with the GPT OSS model family.
# The mailer prefers CEREBRAS_API_KEY_FREE, then CEREBRAS_API_KEY, and can also
# fall back to matching exports in ~/.zshrc when those env vars are absent.
# CEREBRAS_API_KEY_FREE="csk-..."
# CEREBRAS_API_KEY="csk-..."
# MDW_CEREBRAS_MODEL="gpt-oss-120b"
# MDW_CEREBRAS_REASONING_EFFORT="low"
# MDW_CEREBRAS_VERSION_PATCH="2"
