# Copy to .env and customize.

# IB credentials — userid is a plain env var, password uses Docker secrets
TWS_USERID=your_ib_username

# Trading mode: "paper" (default) or "live"
TRADING_MODE=paper

# Read-only API: "yes" (default, recommended for data warehouse) or "no"
READ_ONLY_API=yes

# VNC password — set to enable VNC server on port 5900 for 2FA and monitoring.
# Leave empty to disable VNC (2FA via IBKR mobile app only).
# VNC_SERVER_PASSWORD=your_vnc_password

# Host ports (remap if defaults conflict with other services)
IB_LIVE_PORT=4001
IB_PAPER_PORT=4002
IB_VNC_PORT=5900

# Password secrets file (relative to this directory)
IB_PASSWORD_FILE=./secrets/ib_password.txt
